{
  "datasets": [
    {
      "name": "c6ef7979",
      "displayName": "Hourly sensor trends",
      "queryLines": [
        "-- Powers the line chart showing sensor values over time\r\n",
        "SELECT\r\n",
        "    hour_window,\r\n",
        "    machine_id,\r\n",
        "    sensor_type,\r\n",
        "    avg_value,\r\n",
        "    min_value,\r\n",
        "    max_value,\r\n",
        "    reading_count\r\n",
        "FROM iot_pipeline.sensors_dlt.gold_hourly_stats\r\n",
        "ORDER BY hour_window, machine_id, sensor_type"
      ],
      "catalog": "iot_pipeline",
      "schema": "sensors_dlt"
    },
    {
      "name": "72e4b266",
      "displayName": "Daily reading counts",
      "queryLines": [
        "-- Powers the bar chart showing activity per machine per day\r\n",
        "SELECT\r\n",
        "    TO_DATE(hour_window)     AS date,\r\n",
        "    machine_id,\r\n",
        "    SUM(reading_count)       AS total_readings,\r\n",
        "    ROUND(AVG(avg_value), 4) AS overall_avg\r\n",
        "FROM iot_pipeline.sensors_dlt.gold_hourly_stats\r\n",
        "GROUP BY TO_DATE(hour_window), machine_id\r\n",
        "ORDER BY date, machine_id"
      ],
      "catalog": "iot_pipeline",
      "schema": "sensors_dlt"
    },
    {
      "name": "b59d15e4",
      "displayName": "Daily health scores",
      "queryLines": [
        "SELECT\r\n",
        "    date,\r\n",
        "    machine_id,\r\n",
        "    health_score_pct,\r\n",
        "    machine_status,\r\n",
        "    total_readings,\r\n",
        "    active_sensors,\r\n",
        "    ROUND(avg_temperature, 2) AS avg_temperature,\r\n",
        "    ROUND(avg_pressure, 2)    AS avg_pressure,\r\n",
        "    ROUND(avg_vibration, 4)   AS avg_vibration\r\n",
        "FROM iot_pipeline.sensors_dlt.gold_daily_health\r\n",
        "ORDER BY date, machine_id"
      ],
      "catalog": "iot_pipeline",
      "schema": "sensors_dlt"
    },
    {
      "name": "a0d23059",
      "displayName": "Machine status counters",
      "queryLines": [
        "SELECT\r\n",
        "    SUM(CASE WHEN machine_status = 'NORMAL'   THEN 1 ELSE 0 END) AS normal_count,\r\n",
        "    SUM(CASE WHEN machine_status = 'WARNING'  THEN 1 ELSE 0 END) AS warning_count,\r\n",
        "    SUM(CASE WHEN machine_status = 'CRITICAL' THEN 1 ELSE 0 END) AS critical_count,\r\n",
        "    COUNT(*)                                                       AS total_machine_days,\r\n",
        "    ROUND(AVG(health_score_pct), 1)                               AS avg_health_score\r\n",
        "FROM iot_pipeline.sensors_dlt.gold_daily_health"
      ],
      "catalog": "iot_pipeline",
      "schema": "sensors_dlt"
    },
    {
      "name": "5e626843",
      "displayName": "Anomalies by machine and sensor",
      "queryLines": [
        "SELECT\r\n",
        "    machine_id,\r\n",
        "    sensor_type,\r\n",
        "    COUNT(*)               AS anomaly_count,\r\n",
        "    ROUND(AVG(z_score), 2) AS avg_z_score,\r\n",
        "    ROUND(MAX(z_score), 2) AS max_z_score\r\n",
        "FROM iot_pipeline.sensors_dlt.gold_anomalies\r\n",
        "GROUP BY machine_id, sensor_type\r\n",
        "ORDER BY anomaly_count DESC"
      ],
      "catalog": "iot_pipeline",
      "schema": "sensors_dlt"
    },
    {
      "name": "97cc6a0c",
      "displayName": "Anomaly timeline",
      "queryLines": [
        "SELECT\r\n",
        "    timestamp,\r\n",
        "    machine_id,\r\n",
        "    sensor_type,\r\n",
        "    ROUND(value, 4)        AS value,\r\n",
        "    ROUND(z_score, 2)      AS z_score,\r\n",
        "    ROUND(rolling_avg, 4)  AS rolling_avg\r\n",
        "FROM iot_pipeline.sensors_dlt.gold_anomalies\r\n",
        "ORDER BY timestamp"
      ],
      "catalog": "iot_pipeline",
      "schema": "sensors_dlt"
    },
    {
      "name": "1d0a86a1",
      "displayName": "Quality checks detail",
      "queryLines": [
        "SELECT\r\n",
        "    layer,\r\n",
        "    check_name,\r\n",
        "    ROUND(metric_value, 2) AS metric_value,\r\n",
        "    threshold,\r\n",
        "    status,\r\n",
        "    checked_at\r\n",
        "FROM iot_pipeline.sensors.quality_report\r\n",
        "WHERE run_id = (\r\n",
        "    SELECT MAX(run_id)\r\n",
        "    FROM iot_pipeline.sensors.quality_report\r\n",
        ")\r\n",
        "ORDER BY layer, check_name"
      ],
      "catalog": "iot_pipeline",
      "schema": "sensors"
    },
    {
      "name": "94983f57",
      "displayName": "Quality summary counters",
      "queryLines": [
        "SELECT\r\n",
        "    COUNT(*)                                              AS total_checks,\r\n",
        "    SUM(CASE WHEN status = 'PASS' THEN 1 ELSE 0 END)    AS passed,\r\n",
        "    SUM(CASE WHEN status = 'WARN' THEN 1 ELSE 0 END)    AS warned,\r\n",
        "    SUM(CASE WHEN status = 'FAIL' THEN 1 ELSE 0 END)    AS failed,\r\n",
        "    ROUND(\r\n",
        "        SUM(CASE WHEN status = 'PASS' THEN 1 ELSE 0 END)\r\n",
        "        / COUNT(*) * 100\r\n",
        "    , 0)                                                  AS pass_rate_pct\r\n",
        "FROM iot_pipeline.sensors.quality_report\r\n",
        "WHERE run_id = (\r\n",
        "    SELECT MAX(run_id)\r\n",
        "    FROM iot_pipeline.sensors.quality_report\r\n",
        ")"
      ]
    },
    {
      "name": "9a5ef058",
      "displayName": "Quality Check event_logs",
      "queryLines": [
        "SELECT\r\n",
        "  date(timestamp) AS date,\r\n",
        "  regexp_extract(origin.flow_name, '[^.]+$', 0) AS table_name,\r\n",
        "  sum(details:flow_progress:metrics:num_output_rows) AS output_rows,\r\n",
        "  sum(details:flow_progress:data_quality:dropped_records::long) AS dropped_records,\r\n",
        "  ROUND(\r\n",
        "    sum(details:flow_progress:data_quality:dropped_records::long)\r\n",
        "      / NULLIF(sum(details:flow_progress:metrics:num_output_rows), 0)\r\n",
        "      * 100,\r\n",
        "    2\r\n",
        "  ) AS drop_rate_pct\r\n",
        "FROM\r\n",
        "  iot_pipeline.sensors_dlt.pipeline_sensor_event_logs\r\n",
        "WHERE\r\n",
        "  event_type = 'flow_progress'\r\n",
        "  AND details:flow_progress:status = 'COMPLETED'\r\n",
        "  AND details:flow_progress:metrics:num_output_rows IS NOT NULL\r\n",
        "  AND origin.update_id\r\n",
        "    = (\r\n",
        "      SELECT\r\n",
        "        MAX(origin.update_id)\r\n",
        "      FROM\r\n",
        "        iot_pipeline.sensors_dlt.pipeline_sensor_event_logs\r\n",
        "      WHERE\r\n",
        "        event_type = 'flow_progress'\r\n",
        "        AND details:flow_progress:status = 'COMPLETED'\r\n",
        "    )\r\n",
        "GROUP BY\r\n",
        "  ALL\r\n",
        "ORDER BY\r\n",
        "  date,\r\n",
        "  table_name"
      ]
    }
  ],
